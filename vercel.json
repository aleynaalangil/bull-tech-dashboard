{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' wss: https:; img-src 'self' data:; frame-ancestors 'none'"
        },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/ohlcv/:path*",
      "destination": "https://your-hft-gateway.example.com/api/v1/ohlcv/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://your-exchange-sim.example.com/api/:path*"
    }
  ]
}
